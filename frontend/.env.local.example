# one8 FitLab frontend — environment variables
# Copy to `.env.local` for local dev.

# FastAPI backend base URL (no trailing slash).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Supabase project (Project Settings -> API). The anon key is safe to expose
# to the browser — Row Level Security enforces access control server-side.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
