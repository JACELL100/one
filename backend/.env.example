# one8 FitLab API — environment variables
# Copy to `.env` for local dev. Every value is optional: the API boots with
# safe defaults and gracefully degrades (rules-only ranking, no persistence,
# classical CV fallback) when a given integration isn't configured.

APP_NAME="one8 FitLab API"
ENVIRONMENT=development

# Comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:3000

# --- Supabase (Postgres + Auth + Storage) -----------------------------------
# Project Settings -> API. The service key is server-side only — never ship
# it to the frontend. The JWT secret verifies user access tokens for /scans.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# --- Hosted inference (optional, all free-tier friendly) --------------------
# Hugging Face Inference API token, used for foot segmentation refinement.
HF_API_TOKEN=
HF_SEGMENTATION_MODEL=briaai/RMBG-1.4

# NVIDIA NIM API key (build.nvidia.com), reserved for future pose/vision use.
NVIDIA_API_KEY=

# Optional hosted LLM for natural-language rationale rewriting
# (e.g. an OpenAI-compatible endpoint, NVIDIA NIM, or a HF Inference Endpoint).
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=

# --- Uploads ------------------------------------------------------------------
MAX_UPLOAD_MB=12
